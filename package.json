{
  "name": "@coffeeandfun/konami-code-detector",
  "version": "1.0.0",
  "description": "A modern, async-enabled Konami Code detector",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": "./src/index.js",
